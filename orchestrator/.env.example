# ── Casper Testnet (required for --chain) ──────────────────────────────────
# Funded ed25519 secret key (casper-client keygen + faucet, see docs/DEPLOY.md)
QUORUM_SECRET_KEY_PATH=../contracts/keys/secret_key.pem
QUORUM_NODE_URL=https://node.testnet.casper.network/rpc
QUORUM_CHAIN_NAME=casper-test
# Package hashes printed by the contracts deploy script:
QUORUM_DECISION_LOG=hash-...
QUORUM_TREASURY=hash-...
QUORUM_AGENT_REGISTRY=hash-...

# ── Optional: live MCP enrichment (--mcp) ───────────────────────────────────
# Free key from https://console.cspr.build
#CSPR_CLOUD_API_KEY=
#CASPER_MCP_URL=https://mcp.testnet.cspr.cloud/mcp

# ── Optional: settle x402 payments via the CSPR.cloud facilitator ───────────
# Without these the merchant verifies signatures locally (offline demo mode).
#X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
#X402_FACILITATOR_TOKEN=

# ── Optional: LLM narration of the deliberation (--narrate) ─────────────────
#ANTHROPIC_API_KEY=

# ── Ports ────────────────────────────────────────────────────────────────────
#QUORUM_MERCHANT_PORT=4402
#QUORUM_DASHBOARD_PORT=4400
